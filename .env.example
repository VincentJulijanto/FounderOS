# FounderOS — Environment Variables
# Copy this file to .env and fill in values when keys are available.
# The app runs in mock mode (USE_MOCK_LLM=true) until QWEN_API_KEY is set.

# === QwenCloud API (get from DashScope console) ===
QWEN_API_KEY=                         # <-- paste key here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# === MCP tool server ===
MCP_SERVER_URL=                        # <-- paste URL here

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/founderos

# === App ===
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# === Mock mode (flip to false once QWEN_API_KEY is set) ===
USE_MOCK_LLM=false
