# Frontend env contract. Copy to .env.local and fill in. Never commit .env.local.

# Backend base URL (HF Space in prod, http://localhost:8000 for local dev).
NEXT_PUBLIC_API_BASE_URL=

# --- Auth gate (thin Supabase magic-link gate in front of /boardroom) ---
# OFF by default. "true" turns on /signin, the /boardroom gate, and the header chip.
NEXT_PUBLIC_AUTH_ENABLED=false
# From the Supabase project (Settings > API). Required only when AUTH_ENABLED=true.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
